# ── SusuMate API ────────────────────────────────────────────────
# Base URL of the SusuMate HTTP API, INCLUDING the /api prefix.
# NOTE: app.susumate.app is the web FRONTEND (a SPA) — it is NOT the API.
#       The JSON API is served at susumate.app/api. Point the agent here.
#   production:  https://susumate.app/api
#   local dev:   http://127.0.0.1:8000/api
SUSUMATE_API_URL=https://susumate.app/api
SUSUMATE_API_TIMEOUT_MS=30000

# ── LLM (Qwen Cloud / DashScope, OpenAI-compatible) ─────────────
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
# qwen-plus is fast (~0.6s) with reliable tool-calling. Avoid qwen3.7-max here — it's a
# "thinking" model (~20s/turn), too slow for a chat UX. qwen-flash is the fastest fallback.
AGENT_MODEL_PRIMARY=qwen/qwen-plus
AGENT_MODEL_FALLBACKS=qwen/qwen-flash
# Optional alternate provider (leave blank for Qwen-only):
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# ── WhatsApp (Baileys) ──────────────────────────────────────────
WA_ACCOUNT_ID=default
WA_STATE_DIR=./sessions/wa
WA_MEDIA_DIR=./sessions/media
WA_PRINT_QR=true
# Optional: pair by 8-char code instead of QR (SusuMate number, intl digits only, no +):
WA_PAIR_NUMBER=
WA_MEDIA_MAX_BYTES=20971520

# ── Agent behavior ──────────────────────────────────────────────
AGENT_MAX_TURNS=6
AGENT_USER_DAILY_LIMIT=60
AGENT_GUEST_DAILY_LIMIT=20
AGENT_DEBOUNCE_MS=1500
AGENT_MAX_HISTORY=24

# ── Sessions / secrets ──────────────────────────────────────────
SESSION_STORE=./sessions/store.json
# 32-byte base64 key that encrypts stored user API tokens at rest.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_ENC_KEY=

# ── Runtime ─────────────────────────────────────────────────────
HTTP_PORT=8787
LOG_DIR=./logs
CURRENCY=GHS
