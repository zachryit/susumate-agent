{
  "name": "susumate-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone WhatsApp agent (Mate) for SusuMate — talks to the SusuMate HTTP API on each user's behalf.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "gateway": "tsx src/index.ts",
    "gateway:start": "bin/agent.sh start",
    "gateway:stop": "bin/agent.sh stop",
    "gateway:restart": "bin/agent.sh restart",
    "gateway:status": "bin/agent.sh status",
    "gateway:logs": "bin/agent.sh logs",
    "build": "tsc"
  },
  "dependencies": {
    "baileys": "^7.0.0-rc13",
    "dotenv": "^16.4.7",
    "openai": "^4.77.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
